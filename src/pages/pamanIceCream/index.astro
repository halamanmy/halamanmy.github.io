---
import PIC_Layout from "../../layouts/PIC_Layout.astro";
import PIC_Menu from "../../components/PIC_LP/PIC_Menu.astro";
import PIC_Services from "../../components/PIC_LP/PIC_Services.astro";
// You can create a specific layout for landing pages if you don't want the blog header/footer
---

<!-- <LandingLayout title="Paman Ice Cream | Berbekas di Hati"> -->
<PIC_Layout title="Paman Ice Cream">
  <!-- MAIN -->
  <section id="home" class="hero">
    <div class="hero-content">
      <span class="highlight-text">Aiskrim Kelapa Original Thailand</span>
      <h1 class="title">PAMAN ICE CREAM</h1>
      <p>Cair di mulut, segar di tekak, melekat di hati.</p>

      <div class="cta-group">
        <a href="#menu" class="btn-primary">Lihat Menu</a>
        <a href="https://wa.me/+60182876201" class="btn-whatsapp">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="wa-icon"
            ><path
              d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
            ></path></svg
          >
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- MENU -->
  <PIC_Menu />

  <!-- SERVICES -->
  <PIC_Services />

  <style>
    :root {
      --primary-color: #1dc917; /* Paman Brand Color */
      --accent-light: #a0f79d;
      --text-primary: #111111;
      --text-secondary: #555555;
      --bg-white: #ffffff;
      --bg-menu: #f9fdfd; /* A very light version of your header color */
      --font-family-highlight:
        "Lora", cursive; /* The special highlight font you chose */
      --font-family-sans: "Fredoka", sans-serif; /* Your global bubbly font */
    }

    body {
      background-image:
        linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.7)),
        url("/assets/images/pamanIceCream/bg.webp");
      background-size: cover;
      background-position: center;
      background-attachment: fixed; /* keeps it pinned as you scroll */
      background-repeat: no-repeat;
    }

    /* HERO */
    .hero {
      position: relative;
      min-height: 85vh; /* Takes up 85% of the screen height */
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
      /* Make all text default to white to contrast with the dark overlay */
      color: #ffffff;

      background-image: linear-gradient(
        rgba(0,0,0,0.6),
        rgba(0,0,0,0.8)
      ),
      url('assets/images/pamanIceCream/bg1.webp');

      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }

    /* 2. Centered Content Constraints */
    .hero-content {
      position: relative;
      z-index: 2; /* Keeps the text above the background */
      max-width: 800px;
      width: 100%;
      animation: fadeInUp 0.8s ease-out; /* Simple entrance animation */
    }

    /* 3. Typography */
    .highlight-text {
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.45);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .highlight-text::before,
    .highlight-text::after {
      content: "";
      display: block;
      width: 28px;
      height: 0.5px;
      background: rgba(255, 255, 255, 0.2);
    }

    .title {
      font-size: 3.2rem;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 0.2rem;
      background: linear-gradient(135deg, #35ff2e, #a0ffad 60%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    p {
      font-size: 1.3rem;
      margin-bottom: 2.5rem;
      opacity: 0.9;
      font-weight: 500;
    }

    /* 4. Buttons (Centered in a row) */
    .cta-group {
      display: flex;
      gap: 1rem;
      justify-content: center;
      align-items: center;
      width: 100%;
    }

    .btn-primary,
    .btn-whatsapp {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px; /* Space between icon and text */
      padding: 14px 32px;
      border-radius: 50px;
      text-decoration: none;
      font-weight: 700;
      font-size: 1.1rem;
      white-space: nowrap; /* Prevents text from breaking into two lines */
      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); /* Smoother, modern easing */
    }

    .btn-primary {
      background-color: #ff4d4d;
      color: white;
      border: 2px solid #ff4d4d; /* Border added to match the size if you ever want ghost buttons */
    }

    .btn-whatsapp {
      background-color: #25d366;
      color: white;
      border: 2px solid #25d366;
    }

    /* Hover and Active (Click) States */
    .btn-primary:hover,
    .btn-whatsapp:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.25);
    }

    .btn-primary:active,
    .btn-whatsapp:active {
      transform: translateY(1px); /* Pushes down slightly when tapped */
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }

    /* 5. Mobile Adjustments */
    @media (max-width: 768px) {
      /* ... your other mobile styles (hero, title, p) stay the same ... */

      .cta-group {
        /* Keep them side by side */
        flex-direction: row;
        padding: 0 1rem;
        gap: 0.75rem; /* Slightly smaller gap between buttons */
        max-width: 500px; /* Keeps them from stretching too wide on tablets */
        margin: 0 auto;
      }

      .btn-primary,
      .btn-whatsapp {
        flex: 1; /* Makes both buttons share the width exactly 50/50 */
        padding: 12px 10px; /* Reduced padding to fit the screen */
        font-size: 0.95rem; /* Slightly smaller text for mobile */
      }

      /* Make the SVG slightly smaller on mobile */
      .wa-icon {
        width: 18px;
        height: 18px;
      }
    }
  </style>
</PIC_Layout>
