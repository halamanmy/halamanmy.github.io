---
import AboutHeroImage from "../assets/blog-placeholder-1.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "About";
const description = "About Ruangan.My.";
const site = Astro.site?.href;
const permalink = `${site}about`;
---

<BaseLayout
  title={title}
  description={description}
  permalink={permalink}
  current="about"
>
  <div class="container">
    <h1>The Story Behind the "Space"</h1>
    <figure class="about-image">
      <img
        src="/assets/blog-placeholder-1.jpg"
        alt="Illustration of a notebook"
        width="330"
      />
    </figure>

    <p style="text-align: justify;">
      In Malay, Ruangan means "Space" or "Room." I created Ruangan.My to serve
      as my personal digital workshop—a place where ideas are drafted, systems
      are built, and technical knowledge is shared.
    </p>

    <p style="text-align: justify;">
      I am <a href="https://naquib99.github.io/naquib_portfolio" target="_blank"
        >Naquib</a
      > full-stack developer with a passion for clean code and efficient systems.
      Whether I'm refactoring a UI with Tailwind or troubleshooting a deep-seated
      MySQL query, I believe that every digital product should be as elegant on the
      inside (the code) as it is on the outside (the design).
    </p>

    <p style="text-align: justify;">
      Beyond a personal space, Ruangan.My is built for the tech community. Here,
      I share updates on the latest industry shifts, explore new web frameworks / technology,
      and break down the in-demand tech stacks that actually get you hired.
    </p>
  </div>
</BaseLayout>

<style>
  .about-image {
    float: right;
    margin: -3em -7em 2em 2em;
    max-width: 300px;
  }

  .about-image img {
    border-radius: 8px;
    margin-bottom: 1.5em;
  }

  @media (max-width: 1020px) {
    .about-image {
      float: none;
      margin: 0 auto 2em;
    }
  }
</style>
