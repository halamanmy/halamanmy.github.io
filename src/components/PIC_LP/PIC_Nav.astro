---
const { current = "" } = Astro.props;
const { pathname } = Astro.url;
const isHome = pathname === "/pamanIceCream" || pathname === "/pamanIceCream/";
---

<nav id="pic-nav" class="pic-nav" aria-label="Main navigation">
  <a class="pic-nav__link" data-section="home" href="/pamanIceCream">
    Home
  </a>
  <a class="pic-nav__link" data-section="menu" href="/pamanIceCream#menu">
    Menu
  </a>
  <a class="pic-nav__link" data-section="services" href="/pamanIceCream#services">
    Services
  </a>

  <div class="pic-nav__divider" aria-hidden="true"></div>

  <a
    class="pic-nav__whatsapp"
    href="https://wa.me/+60182876201"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="WhatsApp Kami"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.857L.057 23.999l6.305-1.654A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894a9.875 9.875 0 01-5.032-1.378l-.361-.214-3.741.981.998-3.648-.235-.374A9.858 9.858 0 012.106 12C2.106 6.561 6.561 2.106 12 2.106c5.438 0 9.894 4.455 9.894 9.894 0 5.438-4.456 9.894-9.894 9.894z"/>
    </svg>
    WhatsApp
  </a>
</nav>

<style>
  .pic-nav {
    display: flex;
    align-items: center;
    gap: 2px;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  /* ── Nav links ── */
  .pic-nav__link {
    position: relative;
    display: block;
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.5);
    white-space: nowrap;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .pic-nav__link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.07);
  }

  /* Active underline — use :global so Astro + JS classList both apply it */
  .pic-nav__link:global(.selected),
  .pic-nav__link:global(.active) {
    color: #fff;
  }

  .pic-nav__link:global(.selected)::after,
  .pic-nav__link:global(.active)::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 14px;
    right: 14px;
    height: 2px;
    background: #1dc917;
    border-radius: 99px;
  }

  /* ── Divider ── */
  .pic-nav__divider {
    width: 0.5px;
    height: 18px;
    background: rgba(255, 255, 255, 0.12);
    margin: 0 6px;
    flex-shrink: 0;
  }

  /* ── WhatsApp CTA ── */
  .pic-nav__whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 13px;
    border-radius: 6px;
    border: 0.5px solid rgba(37, 211, 102, 0.3);
    background: rgba(37, 211, 102, 0.08);
    color: #25d366;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }

  .pic-nav__whatsapp:hover {
    background: rgba(37, 211, 102, 0.15);
    border-color: rgba(37, 211, 102, 0.55);
  }

  /* ── Mobile drawer ── */
  @media (max-width: 640px) {
    .pic-nav {
      display: none;
      flex-direction: column;
      align-items: stretch;
      gap: 4px;
      width: 100%;
      padding: 0.75rem 0 1rem;
      border-top: 0.5px solid rgba(255, 255, 255, 0.08);
      order: 3; /* sits below logo + hamburger row */
    }

    .pic-nav.pic-nav--open {
      display: flex;
    }

    .pic-nav__link {
      padding: 10px 16px;
      font-size: 15px;
      border-radius: 8px;
      color: rgba(255, 255, 255, 0.6);
    }

    .pic-nav__link:global(.selected)::after,
    .pic-nav__link:global(.active)::after {
      bottom: 8px;
      left: 16px;
      right: auto;
      width: 24px;
    }

    .pic-nav__divider {
      width: 100%;
      height: 0.5px;
      margin: 4px 0;
    }

    .pic-nav__whatsapp {
      margin: 4px 0 0;
      justify-content: center;
      padding: 10px 16px;
      font-size: 15px;
    }
  }
</style>

<script>
  function initNav() {
    const nav = document.getElementById("pic-nav");
    if (!nav) return;

    const links = nav.querySelectorAll<HTMLAnchorElement>("a[data-section]");
    const sectionIds = ["home", "menu", "services", "contact"];
    const sections = sectionIds
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (sections.length === 0) return;

    const setActive = (id: string) => {
      links.forEach((link) => {
        link.classList.toggle("selected", link.dataset.section === id);
      });
    };

    // Set home as default on load
    setActive("home");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        });
      },
      {
        rootMargin: "-10% 0px -55% 0px",
        threshold: 0,
      }
    );

    sections.forEach((section) => observer.observe(section));
  }

  initNav();
  document.addEventListener("astro:page-load", initNav);
</script>
