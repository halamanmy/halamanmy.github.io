---
const sizes = [
  {
    // icon: "🍦",
    icon: null,
    label: "Kecil",
    image: null,
    price: "RM4",
    desc: "Terbaik untuk merasa pertama kali",
    popular: false,
  },
  {
    // icon: "🥤",
    icon: null,
    label: "Sederhana",
    image: "/assets/images/pamanIceCream/iceCream.webp",
    price: "RM6",
    desc: "Pilihan terbaik untuk semua orang",
    popular: true,
  },
  {
    // icon: "🍨",
    icon: null,
    label: "Besar",
    image: null,
    price: "RM8",
    desc: "Untuk dikongsikan atau untuk mereka yang menyukai aiskrim",
    popular: false,
  },
];

const toppings = [
  "Roti",
  "Sprinkle",
  "Nata de Coco",
  "Kacang Hancur",
  "Koko Krunch",
  "Susu",
  "Pulut",
  "Jagung",
];
---

<section id="menu" class="menu-section">
  <div class="menu-inner">

    <!-- Section header -->
    <div class="menu-header">
      <span class="menu-eyebrow">Apa yang kami tawarkan</span>
      <h2 class="menu-title">Pilih Saiz Anda</h2>
      <p class="menu-subtitle">
        Aiskrim kelapa asli Thailand &mdash; semua saiz, satu rasa
      </p>
    </div>

    <!-- Size cards -->
    <div class="size-grid">
      {
        sizes.map((s) => (
          <div class:list={["size-card", { "size-card--popular": s.popular }]}>
            {s.popular && (
              <span class="size-card__badge" aria-label="Paling popular">
                Paling Popular
              </span>
            )}
            
            <!-- 👈 UPDATED ICON LOGIC HERE -->
            <div class="size-card__icon" aria-hidden="true">
              {s.image ? (
                <img src={s.image} alt={s.label} class="custom-icon-img" />
              ) : (
                s.icon
              )}
            </div>
            
            <span class="size-card__tier">Saiz</span>
            <strong class="size-card__label">{s.label}</strong>
            <p class="size-card__price">
              {s.price}
              <span>/cup</span>
            </p>
            <p class="size-card__desc">{s.desc}</p>
          </div>
        ))
      }
    </div>

    <!-- Toppings divider -->
    <div class="topping-divider" aria-hidden="true">
      <span></span>
      <p>Topping pilihan anda</p>
      <span></span>
    </div>

    <!-- Toppings -->
    <p class="topping-label">Tiada tambahan bayaran &middot; Pilih sesuka hati</p>

    <ul class="topping-list" aria-label="Senarai topping percuma">
      {
        toppings.map((t) => (
          <li class="topping-pill">
            <span class="topping-pill__dot" aria-hidden="true" />
            {t}
          </li>
        ))
      }
    </ul>

    <p class="topping-note">Semua topping percuma dengan setiap pembelian</p>

  </div>
</section>

<style>
  /* ── Section shell ───────────────────────────────────── */
  .menu-section {
    width: 100%;
    padding: 5rem 2rem 6rem;
    color: #fff;
    /* sits on top of body::before fixed background */
  }

  .menu-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  /* ── Header ──────────────────────────────────────────── */
  .menu-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .menu-eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 0.5rem;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  .menu-title {
    font-family: "Lora", serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
    line-height: 1.15;
  }

  .menu-subtitle {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  .custom-icon-img {
    width: 80px; /* Matches the visual size of the 3rem emojis */
    height: 80px;
    object-fit: contain; /* Ensures the image doesn't stretch */
    margin-bottom: 4px;
    /* Optional: Add a slight drop shadow so it blends nicely with the theme */
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2)); 
  }

  /* ── Size grid ───────────────────────────────────────── */
  .size-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 3.5rem;
  }

  .size-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 2rem 1.25rem 1.75rem;
    border-radius: 20px;
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    text-align: center;
    transition: border-color 0.25s ease, background 0.25s ease;
  }

  .size-card:hover {
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.1);
  }

  .size-card--popular {
    border: 1.5px solid rgba(77, 255, 92, 0.55);
    background: rgba(77, 255, 107, 0.08);
  }

  .size-card--popular:hover {
    border-color: rgba(77, 255, 92, 0.8);
    background: rgba(77, 255, 107, 0.14);
  }

  .size-card__badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: #25d366;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 14px;
    border-radius: 99px;
    white-space: nowrap;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  .size-card__icon {
    font-size: 3rem;
    line-height: 1;
    margin-bottom: 4px;
  }

  .size-card__tier {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  .size-card__label {
    font-family: "Lora", serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .size-card__price {
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
    font-size: 2.25rem;
    font-weight: 700;
    color: #25d366;
    line-height: 1;
    margin: 2px 0 0;
  }

  .size-card__price span {
    font-size: 0.95rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.35);
  }

  .size-card__desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1.45;
    margin: 0;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  /* ── Toppings divider ────────────────────────────────── */
  .topping-divider {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 1rem;
    color: rgba(255, 255, 255, 0.3);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  .topping-divider span {
    flex: 1;
    height: 0.5px;
    background: rgba(255, 255, 255, 0.1);
    display: block;
  }

  .topping-divider p {
    margin: 0;
    white-space: nowrap;
  }

  /* ── Toppings ────────────────────────────────────────── */
  .topping-label {
    text-align: center;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.05em;
    margin: 0 0 1.25rem;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  .topping-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .topping-pill {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 7px 16px;
    border-radius: 99px;
    border: 0.5px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    font-weight: 500;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
    cursor: default;
  }

  .topping-pill:hover {
    border-color: rgba(77, 255, 92, 0.4);
    background: rgba(77, 255, 107, 0.08);
    color: #fff;
  }

  .topping-pill__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #25d366;
    flex-shrink: 0;
  }

  .topping-note {
    text-align: center;
    margin-top: 1.25rem;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.04em;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .menu-section {
      padding: 4rem 1.25rem 5rem;
    }

    .menu-title {
      font-size: 1.75rem;
    }

    .size-grid {
      grid-template-columns: 1fr;
      max-width: 320px;
      margin-left: auto;
      margin-right: auto;
    }

    .size-card--popular {
      order: -1; /* Most popular first on mobile */
    }
  }
</style>