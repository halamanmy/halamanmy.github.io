---
// Drop your own images into /public/assets/images/pamanIceCream/
// and update the imageSrc paths below.
const services = [
  {
    tag: "Gerai Harian",
    title: "Beli Terus di Gerai",
    desc: "Singgah dan nikmati aiskrim kelapa segar kami. Gerai kami dibuka setiap petang pada hari tertentu — datang ramai-ramai bersama keluarga!",
    metaIcon: "clock",
    meta: "Ahad, Isnin, Rabu, Khamis, Sabtu: 11.30 pagi – 5.00 petang",
    ctaLabel: "Lokasi kami",
    ctaHref:
      "https://www.google.com/maps/dir//Paman+Ice+cream,+Jalan+Nelayan+19%2FB,+Seksyen+19,+40300+Shah+Alam,+Selangor/@2.9665307,101.5361732,15z/data=!4m8!4m7!1m0!1m5!1m1!1s0x31cc4d54ffb23e93:0xb52df45f53d50877!2m2!1d101.5343549!2d3.0493479?entry=ttu&g_ep=EgoyMDI2MDUwNi4wIKXMDSoASAFQAw%3D%3D",
    ctaExternal: true,
    imageSrc: "/assets/images/pamanIceCream/stall.webp",
    // Fallback colour shown while image loads or if missing
    imageFallback: "#0d1f0d",
  },
  {
    tag: "Tempahan Majlis",
    title: "Aiskrim untuk Majlis",
    desc: "Jadikan majlis anda lebih meriah dengan stesen aiskrim kelapa kami. Sesuai untuk perkahwinan, hari jadi, dan acara korporat.",
    metaIcon: "phone",
    meta: "Hubungi untuk tempahan",
    ctaLabel: "WhatsApp kami",
    ctaHref: "https://wa.me/+60182876201",
    ctaExternal: true,
    imageSrc: "/assets/images/pamanIceCream/event.webp",
    imageFallback: "#1f0d0d",
  },
];
---

<section id="services" class="services-section">
  <div class="services-inner">
    <div class="services-header">
      <span class="services-eyebrow">Apa yang kami sediakan</span>
      <h2 class="services-title">Perkhidmatan Kami</h2>
    </div>

    <div class="services-grid">
      {
        services.map((s) => (
          <div class="svc-card">
            <div
              class="svc-card__bg"
              style={`background-color:${s.imageFallback};background-image:url('${s.imageSrc}')`}
              aria-hidden="true"
            />

            <div class="svc-card__overlay" aria-hidden="true" />

            <div class="svc-card__content">
              <span class="svc-card__tag">{s.tag}</span>
              <h3 class="svc-card__title">{s.title}</h3>
              <p class="svc-card__desc">{s.desc}</p>

              <div class="svc-card__meta">
                {s.metaIcon === "clock" ? (
                  <svg
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12,6 12,12 16,14" />
                  </svg>
                ) : (
                  <svg
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.4 11.8a19.79 19.79 0 01-3.07-8.67A2 2 0 013.3 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 8.37a16 16 0 006.29 6.29l1.46-1.46a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" />
                  </svg>
                )}
                <span>{s.meta}</span>
              </div>

              <a
                href={s.ctaHref}
                class="svc-card__cta"
                {...(s.ctaExternal
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
                aria-label={`${s.ctaLabel} — ${s.title}`}
              >
                {s.ctaLabel} →
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ── Section shell ───────────────────────────────────── */
  .services-section {
    width: 100%;
    padding: 5rem 2rem 6rem;
    color: #fff;
  }

  .services-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  /* ── Header ──────────────────────────────────────────── */
  .services-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .services-eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 0.4rem;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
  }

  .services-title {
    font-family: "Lora", serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.15;
  }

  /* ── Card grid ───────────────────────────────────────── */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  /* ── Individual card ─────────────────────────────────── */
  .svc-card {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    height: 440px;
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    cursor: pointer;
    /* Isolate the stacking context so children z-index works */
    isolation: isolate;
  }

  /* Background image layer */
  .svc-card__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }

  .svc-card:hover .svc-card__bg {
    transform: scale(1.07);
  }

  /* Dark gradient overlay */
  .svc-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.88) 0%,
      rgba(0, 0, 0, 0.35) 50%,
      rgba(0, 0, 0, 0.12) 100%
    );
    transition: background 0.4s ease;
    z-index: 1;
  }

  .svc-card:hover .svc-card__overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.94) 0%,
      rgba(0, 0, 0, 0.55) 55%,
      rgba(0, 0, 0, 0.28) 100%
    );
  }

  /* Content layer */
  .svc-card__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.75rem;
  }

  /* ── Tag pill ────────────────────────────────────────── */
  .svc-card__tag {
    display: inline-block;
    align-self: flex-start;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 99px;
    border: 0.5px solid rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 0.75rem;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
    transition:
      background 0.3s ease,
      color 0.3s ease,
      border-color 0.3s ease;
  }

  .svc-card:hover .svc-card__tag {
    background: rgba(255, 77, 77, 0.2);
    border-color: rgba(255, 77, 77, 0.5);
    color: #ff9a9a;
  }

  /* ── Title ───────────────────────────────────────────── */
  .svc-card__title {
    font-family: "Lora", serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.4rem;
    line-height: 1.2;
  }

  /* ── Description — hidden until hover ───────────────── */
  .svc-card__desc {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.55;
    margin: 0;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);

    /* Reveal on hover */
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.4s ease,
      opacity 0.35s ease,
      margin 0.3s ease;
  }

  .svc-card:hover .svc-card__desc {
    max-height: 120px;
    opacity: 1;
    margin-bottom: 0.75rem;
  }

  /* ── Meta row (time / contact) ───────────────────────── */
  .svc-card__meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);
    margin-top: 0.35rem;
  }

  .svc-card__meta svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* ── CTA button — slides up on hover ────────────────── */
  .svc-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 0.9rem;
    padding: 8px 18px;
    border-radius: 8px;
    background: rgba(255, 77, 77, 0.15);
    border: 0.5px solid rgba(255, 77, 77, 0.4);
    color: #ff9a9a;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    align-self: flex-start;
    font-family: var(--font-family-sans, "Fredoka", system-ui, sans-serif);

    /* Hidden until hover */
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease,
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .svc-card:hover .svc-card__cta {
    opacity: 1;
    transform: translateY(0);
  }

  .svc-card__cta:hover {
    background: rgba(255, 77, 77, 0.3);
    border-color: rgba(255, 77, 77, 0.7);
    color: #fff;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .services-section {
      padding: 4rem 1.25rem 5rem;
    }

    .services-title {
      font-size: 1.75rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .svc-card {
      height: 360px;
    }

    /* On mobile, always show desc and cta since there's no hover */
    .svc-card__desc {
      max-height: 120px;
      opacity: 1;
      margin-bottom: 0.75rem;
    }

    .svc-card__cta {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
