<script>
  const filterBar = document.getElementById("phone-filter-bar-2025");
  const list = document.getElementById("phone-list-2025");

  filterBar?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".fil");
    if (!btn) return;

    filterBar.querySelectorAll(".fil").forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");

    const filter = btn.dataset.filter ?? "all";

    list?.querySelectorAll<HTMLElement>(".phone-card").forEach((card) => {
      const tags = card.dataset.tags ?? "";
      const visible = filter === "all" || tags.includes(filter);
      card.classList.toggle("is-hidden", !visible);
    });
  });
</script>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0.75rem 0 1.25rem;
    border-bottom: 0.5px solid rgba(0, 0, 0, 0.1);
    margin-bottom: 1.25rem;
  }

  .fil {
    font-size: 12px;
    font-weight: 500;
    padding: 5px 14px;
    border-radius: 99px;
    border: 0.5px solid rgba(0, 0, 0, 0.15);
    background: transparent;
    color: #666;
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: inherit;
  }

  .fil:hover {
    background: rgba(0, 0, 0, 0.04);
    color: #111;
    border-color: rgba(0, 0, 0, 0.25);
  }

  .fil.active {
    background: #111;
    color: #fff;
    border-color: transparent;
  }

  .phone-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .phone-list :global(.phone-card.is-hidden) {
    display: none;
  }

  @media (prefers-color-scheme: dark) {
    .filter-bar {
      border-bottom-color: rgba(255, 255, 255, 0.08);
    }

    .fil {
      border-color: rgba(255, 255, 255, 0.15);
      color: #999;
    }

    .fil:hover {
      background: rgba(255, 255, 255, 0.06);
      color: #eee;
      border-color: rgba(255, 255, 255, 0.25);
    }

    .fil.active {
      background: #f0f0ee;
      color: #111;
      border-color: transparent;
    }
  }
</style>