  />

  <LaptopCard
    rank={9}
    name="MSI Modern 15"
    tagline='The "Minimalist" Choice — stealthy, no-frills, no RGB'
    processor="AMD Ryzen 5 7530U"
    ram="16GB"
    price="~RM 2,499"
    affiliateUrl="https://s.shopee.com.my/AUpZy9tW9h?share_channel_code=1"
    tags={["web", "budget"]}
  />

  <LaptopCard
    rank={10}
    name="Acer Aspire Go 14"
    tagline="The Student's First Rig — sleek, light, incredible battery"
    processor="AMD Ryzen 5 7000 Series (or Intel Core i3-N)"
    ram="16GB (check variant — some ship with 8GB)"
    price="~RM 2,299 – RM 2,499"
    highlight="Best entry point on this list. Perfect for CS students."
    affiliateUrl="https://s.shopee.com.my/7fVObbj8TO?share_channel_code=1"
    tags={["budget", "web"]}
  />
</div>

<script>
  const filterBar = document.getElementById("filter-bar");
  const list = document.getElementById("laptop-list");

  filterBar?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".fil");
    if (!btn) return;

    filterBar
      .querySelectorAll(".fil")
      .forEach((b) => b.classList.remove("active"));
    btn.classList.add("active");

    const filter = btn.dataset.filter ?? "all";

    list?.querySelectorAll<HTMLElement>(".laptop-card").forEach((card) => {
      const tags = card.dataset.tags ?? "";
      const visible = filter === "all" || tags.includes(filter);
      card.classList.toggle("is-hidden", !visible);
    });
  });
</script>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0.75rem 0 1.25rem;
    border-bottom: 0.5px solid rgba(0, 0, 0, 0.1);
    margin-bottom: 1.25rem;
  }

  .fil {
    font-size: 12px;
    font-weight: 500;
    padding: 5px 14px;
    border-radius: 99px;
    border: 0.5px solid rgba(0, 0, 0, 0.15);
    background: transparent;
    color: #666;
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: inherit;
  }

  .fil:hover {
    background: rgba(0, 0, 0, 0.04);
    color: #111;
    border-color: rgba(0, 0, 0, 0.25);
  }

  .fil.active {
    background: #111;
    color: #fff;
    border-color: transparent;
  }

  .laptop-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Target the card rendered by LaptopCard.astro */
  .laptop-list :global(.laptop-card.is-hidden) {
    display: none;
  }

  @media (prefers-color-scheme: dark) {
    .filter-bar {
      border-bottom-color: rgba(255, 255, 255, 0.08);
    }

    .fil {
      border-color: rgba(255, 255, 255, 0.15);
      color: #999;
    }

    .fil:hover {
      background: rgba(255, 255, 255, 0.06);
      color: #eee;
      border-color: rgba(255, 255, 255, 0.25);
    }

    .fil.active {
      background: #f0f0ee;
      color: #111;
      border-color: transparent;
    }
  }
</style>
