---
import LaptopCard from "./LaptopCard.astro";
---

<div class="filter-bar" id="filter-bar">
  <button class="fil active" data-filter="all">All picks</button>
  <button class="fil" data-filter="web">Web dev</button>
  <button class="fil" data-filter="backend">Backend / Docker</button>
  <button class="fil" data-filter="mobile">Mobile dev</button>
  <button class="fil" data-filter="nomad">On the go</button>
  <button class="fil" data-filter="budget">Strict budget</button>
</div>

<div class="laptop-list" id="laptop-list">
  <LaptopCard
    rank={1}
    name="Lenovo ThinkPad E14"
    tagline='The "Reliable Workhorse" — legendary keyboard, military-grade durability'
    processor="AMD Ryzen 7"
    ram="16GB"
    price="~RM 3,200"
    highlight="Spill-resistant keyboard. MIL-SPEC durability."
    affiliateUrl="https://s.shopee.com.my/50UdPJ2Esn?share_channel_code=1"
    tags={["web", "backend", "nomad"]}
    featured={true}
  />

  <LaptopCard
    rank={2}
    name="ASUS Vivobook 16 (A1605)"
    tagline='The "Screen Real Estate" King — side-by-side windows with ease'
    processor="Intel Core i5-13420H (13th Gen)"
    ram="16GB DDR4 (upgradeable)"
    price="~RM 2,699"
    affiliateUrl="https://s.shopee.com.my/6L00zvIyJR?share_channel_code=1"
    tags={["web", "budget"]}
  />

  <LaptopCard
    rank={3}
    name="Acer Swift Go 14 (AI Edition)"
    tagline='The "Coffee Shop" Favorite — stunning OLED, ultra-light'
    processor="Intel Core Ultra 5 225H"
    ram="16GB LPDDR5X"
    price="~RM 3,799"
    highlight="OLED display reduces eye strain during late-night sessions."
    affiliateUrl="https://s.shopee.com.my/5VQu0Y4UdU?share_channel_code=1"
    tags={["nomad", "mobile"]}
  />

  <LaptopCard
    rank={4}
    name="HP Pavilion Plus 14"
    tagline='The "All-Rounder" — premium feel, great webcam for stand-ups'
    processor="AMD Ryzen 7 8845H"
    ram="16GB"
    price="~RM 3,899"
    affiliateUrl="https://s.shopee.com.my/4qBDDPIYR7?share_channel_code=1"
    tags={["web", "mobile"]}
  />

  <LaptopCard
    rank={5}
    name="MacBook Air M2"
    tagline='The "Battery Life" Champion — all-day power, no charger anxiety'
    processor="Apple M2 Chip"
    ram="8GB (16GB recommended for Docker)"
    price="~RM 3,999"
    highlight="Only pick 8GB on a strict budget — hunt for 16GB promos if you use Docker."
    affiliateUrl="https://s.shopee.com.my/60NAbcUInA?share_channel_code=1"
    tags={["ios", "nomad"]}
  />

  <LaptopCard
    rank={6}
    name="Dell Inspiron 14"
    tagline='The "Zero Downtime" Choice — on-site warranty, freelancer-safe'
    processor="Intel Core i5-1335U"
    ram="16GB"
    price="~RM 3,199"
    highlight="On-site warranty — a technician comes to you if hardware fails."
    affiliateUrl="https://s.shopee.com.my/LinrKUUie?share_channel_code=1"
    tags={["web", "nomad"]}
  />

  <LaptopCard
    rank={7}
    name="Honor MagicBook X16"
    tagline='The "MacBook Clone" on a budget — thin 16" chassis, Windows/Linux ready'
    processor="Intel Core i5-12450H"
    ram="16GB"
    price="~RM 2,999"
    affiliateUrl="https://s.shopee.com.my/8V4VaOFrOK?share_channel_code=1"
    tags={["web", "budget"]}
  />

  <LaptopCard
    rank={8}
    name="Lenovo LOQ 15 (Gen 9)"
    tagline='The "Heavy Lifter" — built for sustained loads, no throttling'
