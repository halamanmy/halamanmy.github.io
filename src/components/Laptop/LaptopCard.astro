---
interface Props {
  rank: number;
  name: string;
  tagline: string;
  processor: string;
  ram: string;
  price: string;
  highlight?: string;
  affiliateUrl: string;
  tags: string[]; // used for filter: "web" | "backend" | "mobile" | "nomad" | "budget" | "ios"
  featured?: boolean;
}

const {
  rank,
  name,
  tagline,
  processor,
  ram,
  price,
  highlight,
  affiliateUrl,
  tags,
  featured = false,
} = Astro.props;

const tagLabels: Record<string, string> = {
  web: "web dev",
  backend: "backend",
  mobile: "mobile dev",
  nomad: "on the go",
  budget: "budget pick",
  ios: "ios dev",
};
---

<article
  class:list={["laptop-card", { "laptop-card--featured": featured }]}
  data-tags={tags.join(" ")}
>
  <div class="laptop-card__rank">
    {String(rank).padStart(2, "0")}
  </div>

  <div class="laptop-card__body">
    <div class="laptop-card__header">
      <div>
        <h3 class="laptop-card__name">{name}</h3>
        <p class="laptop-card__tagline">{tagline}</p>
      </div>
      {featured && <span class="laptop-card__badge">Editor's pick</span>}
    </div>

    <dl class="laptop-card__specs">
      <div class="laptop-card__spec">
        <dt>CPU</dt>
        <dd>{processor}</dd>
      </div>
      <div class="laptop-card__spec">
        <dt>RAM</dt>
        <dd>{ram}</dd>
      </div>
      {
        highlight && (
          <div class="laptop-card__spec laptop-card__spec--highlight">
            <dt>Note</dt>
            <dd>{highlight}</dd>
          </div>
        )
      }
    </dl>

    <div class="laptop-card__tags">
      {
        tags.map((t) => (
          <span class={`laptop-card__tag laptop-card__tag--${t}`}>
            {tagLabels[t] ?? t}
          </span>
        ))
      }
    </div>
  </div>

  <div class="laptop-card__cta">
    <p class="laptop-card__price">{price}</p>
    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener noreferrer nofollow"
      class="laptop-card__buy"
      aria-label={`Buy ${name} on Shopee`}
    >
      View on Shopee
      <svg
        width="12"
        height="12"
        viewBox="0 0 12 12"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M2 10L10 2M10 2H4M10 2V8"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </div>
</article>

<style>
  .laptop-card {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    gap: 1rem;
    align-items: start;
    padding: 1.125rem 1.25rem;
    border: 0.5px solid var(--color-border, rgba(0, 0, 0, 0.1));
    border-radius: 14px;
    background: var(--color-card, #fff);
    transition:
      border-color 0.2s ease,
      transform 0.15s ease;
  }

  .laptop-card:hover {
    border-color: var(--color-border-hover, rgba(0, 0, 0, 0.2));
    transform: translateY(-1px);
  }

  .laptop-card--featured {
    border-color: rgba(24, 95, 165, 0.3);
    background: var(--color-featured-bg, #fafcff);
  }

  .laptop-card--featured:hover {
    border-color: rgba(24, 95, 165, 0.55);
  }

  /* ── Rank number ─── */
  .laptop-card__rank {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-rank, rgba(0, 0, 0, 0.2));
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
    padding-top: 3px;
  }

  /* ── Body ─── */
  .laptop-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .laptop-card__name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary, #111);
    margin: 0 0 2px;
    line-height: 1.2;
  }

  .laptop-card__tagline {
    font-size: 13px;
    color: var(--text-secondary, #666);
    margin: 0;
    line-height: 1.4;
  }

  .laptop-card__badge {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #0c447c;
    background: #e6f1fb;
    padding: 3px 8px;
    border-radius: 99px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Specs ─── */
  .laptop-card__specs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
    margin: 0 0 0.75rem;
  }

  .laptop-card__spec {
    display: flex;
    gap: 5px;
    align-items: baseline;
  }

  .laptop-card__spec dt {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary, #aaa);
    font-weight: 500;
  }

  .laptop-card__spec dd {
    font-size: 12px;
    color: var(--text-secondary, #555);
    margin: 0;
  }

  .laptop-card__spec--highlight dd {
    color: var(--text-primary, #222);
    font-style: italic;
  }

  /* ── Tags ─── */
  .laptop-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .laptop-card__tag {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 9px;
    border-radius: 99px;
  }

  .laptop-card__tag--web {
    background: #e6f1fb;
    color: #0c447c;
  }
  .laptop-card__tag--backend {
    background: #faeeda;
    color: #633806;
  }
  .laptop-card__tag--mobile {
    background: #eeedfe;
    color: #3c3489;
  }
  .laptop-card__tag--nomad {
    background: #e1f5ee;
    color: #085041;
  }
  .laptop-card__tag--budget {
    background: #f1efe8;
    color: #444441;
  }
  .laptop-card__tag--ios {
    background: #fbeaf0;
    color: #72243e;
  }

  /* ── CTA ─── */
  .laptop-card__cta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    min-width: 110px;
  }

  .laptop-card__price {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-primary, #111);
    margin: 0;
    white-space: nowrap;
  }

  .laptop-card__buy {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 500;
    padding: 6px 13px;
    border-radius: 8px;
    border: 0.5px solid rgba(0, 0, 0, 0.15);
    color: var(--text-primary, #111);
    background: transparent;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 0.15s,
      border-color 0.15s;
  }

  .laptop-card__buy:hover {
    background: var(--color-background-secondary, #f5f5f3);
    border-color: rgba(0, 0, 0, 0.25);
  }

  /* ── Responsive ─── */
  @media (max-width: 560px) {
    .laptop-card {
      grid-template-columns: 28px 1fr;
      grid-template-rows: auto auto;
    }

    .laptop-card__cta {
      grid-column: 2;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      min-width: unset;
    }
  }

  /* ── Dark mode ─── */
  @media (prefers-color-scheme: dark) {
    .laptop-card {
      background: #1c1c1a;
      border-color: rgba(255, 255, 255, 0.08);
    }

    .laptop-card:hover {
      border-color: rgba(255, 255, 255, 0.18);
    }

    .laptop-card--featured {
      background: #161c24;
      border-color: rgba(55, 138, 221, 0.25);
    }

    .laptop-card--featured:hover {
      border-color: rgba(55, 138, 221, 0.5);
    }

    .laptop-card__rank {
      color: rgba(255, 255, 255, 0.18);
    }

    .laptop-card__name {
      color: #f0f0ee;
    }

    .laptop-card__tagline {
      color: #999;
    }

    .laptop-card__spec dd {
      color: #888;
    }

    .laptop-card__spec--highlight dd {
      color: #ccc;
    }

    .laptop-card__price {
      color: #f0f0ee;
    }

    .laptop-card__buy {
      color: #ddd;
      border-color: rgba(255, 255, 255, 0.15);
    }

    .laptop-card__buy:hover {
      background: rgba(255, 255, 255, 0.07);
      border-color: rgba(255, 255, 255, 0.25);
    }

    .laptop-card__tag--web {
      background: #0c447c;
      color: #b5d4f4;
    }
    .laptop-card__tag--backend {
      background: #633806;
      color: #fac775;
    }
    .laptop-card__tag--mobile {
      background: #3c3489;
      color: #cecbf6;
    }
    .laptop-card__tag--nomad {
      background: #085041;
      color: #9fe1cb;
    }
    .laptop-card__tag--budget {
      background: #2c2c2a;
      color: #b4b2a9;
    }
    .laptop-card__tag--ios {
      background: #72243e;
      color: #f4c0d1;
    }
  }
</style>
