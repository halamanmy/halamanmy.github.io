---
import { ClientRouter } from "astro:transitions";
import Footer from "../components/PIC_LP/PIC_Footer.astro";
import Header from "../components/PIC_LP/PIC_Header.astro";
import BaseHead from "../components/BaseHead.astro";

const { title, description, permalink } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <BaseHead title={title} description={description} permalink={permalink} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/faviconPIC.ico" />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;700&family=Lora&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="layout">
      <Header current="home" />
      <slot />
      <Footer />
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --brand-primary: #1dc917;
    --brand-bg: #e8ffe7;
  }
  .layout {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    min-height: 100vh;
  }

  main {
    flex: 1;
    position: relative;
    margin: 0 auto;
    max-width: 1400px;
    padding: 1em 2em;
    box-sizing: border-box;
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  body {
    margin: 0;
    padding: 0;
    font-family: "Fredoka", system-ui, sans-serif;
    background-color: var(--brand-bg);
  }
</style>

<ClientRouter />

<!-- This is intentionally inlined to avoid FOUC -->
<script is:inline>
  const root = document.documentElement;
  const theme = localStorage.getItem("theme");
  if (
    theme === "dark" ||
    (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)
  ) {
    root.classList.add("theme-dark");
  } else {
    root.classList.remove("theme-dark");
  }
</script>
